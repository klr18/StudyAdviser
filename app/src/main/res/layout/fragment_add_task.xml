<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:spacing="12dp">

            <!-- Название задачи -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Название задачи"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Поле для ввода названия задачи" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Описание задачи -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Описание задачи"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:maxLines="3"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Поле для ввода описания задачи" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Статус задачи -->
            <Spinner
                android:id="@+id/spinnerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:importantForAccessibility="yes"
                android:contentDescription="Выбор статуса задачи" />

            <!-- Кнопки для даты и времени -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/buttonDate"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Дата"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Выбор даты" />

                <Button
                    android:id="@+id/buttonTime"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Время"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Выбор времени" />
            </LinearLayout>

            <!-- Дата и время задачи -->
            <TextView
                android:id="@+id/textDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="16dp"
                android:text="Выберите дату и время" />

            <!-- Категория задачи -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Категория">

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:entries="@array/categories"
                    android:importantForAccessibility="yes"
                    android:contentDescription="Выбор категории задачи" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Кнопка для сохранения задачи -->
            <Button
                android:id="@+id/buttonSave"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Сохранить задачу"
                android:layout_marginTop="16dp"
                android:importantForAccessibility="yes"
                android:contentDescription="Кнопка сохранения задачи" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
